local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")
local hum = char:WaitForChild("Humanoid")
local camera = workspace.CurrentCamera

-- إنشاء واجهة بسيطة
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local Main = Instance.new("Frame", ScreenGui)
Main.Size, Main.Position, Main.BackgroundColor3 = UDim2.new(0, 140, 0, 90), UDim2.new(0.5, -70, 0.2, 0), Color3.fromRGB(30, 30, 30)
Main.Active, Main.Draggable = true, true

local Title = Instance.new("TextLabel", Main)
Title.Size, Title.Text, Title.TextColor3 = UDim2.new(1, 0, 0, 25), "FLY PRO", Color3.new(1, 1, 1)
Title.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

local FlyBtn = Instance.new("TextButton", Main)
FlyBtn.Size, FlyBtn.Position, FlyBtn.Text = UDim2.new(0.8, 0, 0, 35), UDim2.new(0.1, 0, 0.45, 0), "الطيران: إيقاف"
FlyBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)

-- متغيرات الطيران
local flying = false
local speed = 50
local bv, bg

FlyBtn.MouseButton1Click:Connect(function()
    flying = not flying
    if flying then
        FlyBtn.Text, FlyBtn.BackgroundColor3 = "الطيران: يعمل", Color3.fromRGB(0, 150, 0)
        
        -- إلغاء الجاذبية
        bv = Instance.new("BodyVelocity", root)
        bg = Instance.new("BodyGyro", root)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0, 0, 0)
        
        hum.PlatformStand = true -- يمنع حركة الأقدام (الركض) ليكون طيران حقيقي
        
        task.spawn(function()
            while flying do
                local moveDir = hum.MoveDirection -- يقرأ حركة الجويستيك
                if moveDir.Magnitude > 0 then
                    bv.Velocity = moveDir * speed
                else
                    bv.Velocity = Vector3.new(0, 0, 0) -- ثبات إذا لم تلمس الجويستيك
                end
                bg.CFrame = camera.CFrame
                task.wait()
            end
            if bv then bv:Destroy() end
            if bg then bg:Destroy() end
            hum.PlatformStand = false
        end)
    else
        FlyBtn.Text, FlyBtn.BackgroundColor3 = "الطيران: إيقاف", Color3.fromRGB(150, 0, 0)
    end
end)
